{
  "documentId": "mermaid-guide",
  "documentType": "Skill",
  "schemaRef": "SkillSchema/v1",
  "skillKind": "custom",
  "status": "ACTIVE",
  "content": {
    "title": {
      "blockType": "Title",
      "title": "Mermaid構文パターンの参照を行うSkill：mermaid-guide"
    },
    "purpose": {
      "blockType": "Purpose",
      "title": "目的",
      "text": "Mermaidの構文パターンを参照・選択したいとき、図の表現方法を決めたいとき、Mermaidの記法を確認したいとき、またはknowledgeSkillsで図を作成するときに使う。「どのMermaid構文を使うか」「この図はどう書くか」「Mermaidで〜を表現したい」と言われたときに使う。"
    },
    "inputExpectation": {
      "blockType": "InputExpectation",
      "title": "入力の想定",
      "items": [
        {
          "aspect": "表現したい図の内容・目的",
          "interpretation": "対応する構文が不明な場合はreferences/syntax-overview.mdの選択基準に従って判定する。"
        }
      ]
    },
    "role": {
      "blockType": "Role",
      "title": "役割",
      "items": [
        "図の内容・目的に応じた最適なMermaid構文を選定する",
        "各構文の基本テンプレートと実例を提供する",
        "Skills間で統一されたMermaid記法を保証する"
      ]
    },
    "processingTarget": {
      "blockType": "ProcessingTarget",
      "title": "処理対象と成果物",
      "target": "表現したい図の内容・目的（他Skillsからの参照を含む）。",
      "artifact": "選定した構文のテンプレートに従って生成したMermaid図。"
    },
    "steps": {
      "blockType": "CustomSteps",
      "title": "実行手順",
      "items": [
        {
          "stepId": "step-1",
          "title": "構文を選定する",
          "summary": "references/syntax-overview.mdを読み込み、表現したい内容に対応する構文を特定する。"
        },
        {
          "stepId": "step-2",
          "title": "パターンファイルを読み込む",
          "summary": "特定した構文のreferences/pattern-{構文名}.mdを読み込み、テンプレートと実例を参照する。"
        },
        {
          "stepId": "step-3",
          "title": "図を生成する",
          "summary": "パターンファイルのテンプレートに従って図を生成する。"
        }
      ]
    },
    "outputFormat": {
      "blockType": "OutputFormat",
      "title": "出力形式",
      "text": ""
    },
    "guardrails": {
      "blockType": "Guardrails",
      "title": "ガードレール",
      "items": [
        "graph構文は使用しない。フローチャートは必ずflowchartを使う（旧構文のため）",
        "判断フロー（YES/NO分岐）はMermaidではなくテキスト形式（コードブロック）で表現する",
        "beta構文（sankey-beta, xychart-beta, architecture-beta, block-beta）は表示環境に依存するため、使用時は注意を促す"
      ]
    },
