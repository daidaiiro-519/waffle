{
  "documentId": "harness-query-engine",
  "documentType": "Skill",
  "schemaRef": "SkillSchema/v1",
  "skillKind": "engine",
  "status": "DRAFT",
  "tags": [
    "engine:query"
  ],
  "createdAt": "2026-06-26T00:00:00Z",
  "updatedAt": "2026-06-26T00:00:00Z",
  "content": {
    "purpose": {
      "blockType": "Purpose",
      "title": "目的",
      "text": "document.json および通常ファイルに対してセマンティック操作によるクエリを実行し、{ prompt, value } 形式で結果を返す。AI がファイルを直接読んで解釈することなく、Python スクリプトが一切のデータアクセスを担う。"
    },
    "role": {
      "blockType": "Role",
      "title": "役割",
      "items": [
        "セマンティック操作（16本）を受け取り、対応する Python 処理にルーティングする",
        "content 各ブロックの blockType から schema の x-prompt-query を引いて index を動的算出するインデックス走査（ファイル / ディレクトリ横断）を実行する。index は document.json に保存しない",
        "document.json の blockKey 単位でコンテンツを取得する（ブロックレベル操作）",
        "配列の取得・スライス・key/正規表現フィルタ・id 検索・ネスト展開・全階層の再帰検索を実行する",
        "schemaRef を持たない通常ファイルを raw フォールバックとして返す",
        "すべてのエラーを { error, message } 形式でラップして返す（例外を AI に素通りさせない）"
      ]
    },
    "interface": {
      "blockType": "Interface",
      "title": "インターフェース",
      "input": [
        {
          "name": "operation",
          "type": "string",
          "required": true,
          "description": "セマンティック操作名（一覧は Step 2 のオペレーション表で選ぶ）",
          "example": "get_block"
        },
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "対象ファイル（index_scan_dir はディレクトリ）。要望テキストで指定される",
          "example": ".waffle/documents/skills/harness-query-engine.json"
        },
        {
          "name": "blockKey",
          "type": "string",
          "required": false,
          "description": "取得するブロックのキー（Group 2・3 で必須）",
          "example": "interface"
        },
        {
          "name": "arrayField",
          "type": "string",
          "required": false,
          "description": "操作対象の配列フィールド名（Group 3 で必須）",
          "example": "input"
        },
        {
          "name": "field",
          "type": "string",
          "required": false,
          "description": "取得/フィルタ対象のフィールド名",
          "example": "description"
        },
        {
          "name": "idField",
          "type": "string",
          "required": false,
          "description": "ID として使うフィールド名",
          "example": "stepId"
        },
        {
          "name": "idValue",
          "type": "string",
          "required": false,
          "description": "ID の値",
          "example": "step-1"
        },
        {
          "name": "key",
          "type": "string",
          "required": false,
          "description": "フィルタ条件のキー名（filter_items）",
          "example": "required"
        },
        {
          "name": "value",
          "type": "any",
          "required": false,
          "description": "フィルタ条件の値（filter_items）",
          "example": "true"
        },
        {
          "name": "pattern",
          "type": "string",
          "required": false,
          "description": "正規表現（filter_pattern）",
          "example": "^uc-"
        },
        {
          "name": "start",
          "type": "integer",
          "required": false,
          "description": "スライス開始（get_items_slice）",
          "example": "0"
        },
        {
          "name": "end",
          "type": "integer",
          "required": false,
          "description": "スライス終了（get_items_slice）",
          "example": "5"
        },
        {
          "name": "fieldName",
          "type": "string",
          "required": false,
          "description": "再帰検索するフィールド名（find_all）",
          "example": "stepId"
        },
        {
          "name": "nestedField",
          "type": "string",
          "required": false,
          "description": "展開するネスト配列（get_nested_items）",
          "example": "children"
        }
      ],
      "output": [
        {
          "name": "prompt",
          "type": "string/null",
          "required": true,
          "description": "value の読み方の指針（blockType→x-prompt-query から動的算出）。Group 1・再帰では null",
          "example": "この engine の I/O 定義を持ちます…"
        },
        {
          "name": "value",
          "type": "any",
          "required": true,
          "description": "クエリ結果（そのまま返る・型は operation 依存）",
          "example": "[{ \"name\": \"operation\", … }]"
        },
        {
          "name": "type",
          "type": "string",
          "required": false,
          "description": "raw フォールバック時のみ \"raw\"",
          "example": "raw"
        },
        {
          "name": "content",
          "type": "string",
          "required": false,
          "description": "raw フォールバック時のみ。生テキスト",
          "example": "# README…"
        },
        {
          "name": "error",
          "type": "string",
          "required": false,
          "description": "エラー時のみ。INVALID_OPERATION/INVALID_PATH/INVALID_JSON/INVALID_PATTERN/MISSING_PARAM/NOT_FOUND/NO_MATCH",
          "example": "MISSING_PARAM"
        },
        {
          "name": "message",
          "type": "string",
          "required": false,
          "description": "エラー時のみ。人間可読の詳細",
          "example": "blockKey は get_block で必須です"
        }
      ]
    },
    "invocationSpec": {
      "blockType": "InvocationSpec",
      "title": "呼び出し",
      "cliTemplate": "uv run --project waffle waffle query --operation <operation> --path <path> [--<param> <value> ...]",
      "cliExamples": [
        "uv run --project waffle waffle query --operation get_block --path .waffle/documents/skills/harness-query-engine.json --blockKey interface",
        "uv run --project waffle waffle query --operation filter_items --path .waffle/documents/skills/harness-query-engine.json --blockKey interface --arrayField input --key required --value true"
      ],
      "mcpTemplate": "query_document({ \"operation\": \"<operation>\", \"path\": \"<path>\", ...<param>: <value> })",
      "mcpExamples": [
        "query_document({\"operation\": \"get_block\", \"path\": \".waffle/documents/skills/harness-query-engine.json\", \"blockKey\": \"interface\"})"
      ],
      "note": "MCP は uv run --project waffle waffle serve 起動後に利用可。"
    },
    "title": {
      "blockType": "Title",
      "title": "harness-query-engine"
    },
    "steps": {
      "blockType": "EngineSteps",
      "title": "実行手順",
      "items": [
        {
          "stepId": "step-1",
          "title": "要望テキストから対象と取得内容を読み取る",
          "summary": "対象 path（ファイル/フォルダ）は要望テキストに含まれている前提（呼び出し側＝Orchestrator が指定）。無ければ『対象の指定が必要』と返す。あわせて、どの意味的単位（ブロック/フィールド/条件）が欲しいかを読み取る。"
        },
        {
          "stepId": "step-2",
          "title": "オペレーションを選ぶ",
          "summary": "欲しい結果から下表で operation を1つ選び、必須引数を『インターフェース』のパラメータ表で成型する。",
          "bullets": [
            "構造を知りたい → `index_scan` / `index_scan_dir`",
            "特定ブロック → `get_block` / `get_field`",
            "配列を絞る → `filter_items` / `filter_pattern` / `get_by_id`",
            "全階層検索 → `find_all`"
          ],
          "operations": [
            {
              "operation": "scan",
              "purpose": "生テキスト取得",
              "params": "-",
              "example": "path=README.md"
            },
            {
              "operation": "get_meta",
              "purpose": "メタ情報(documentId/status 等)",
              "params": "-",
              "example": "path=<doc>"
            },
            {
              "operation": "index_scan",
              "purpose": "1 doc の block 一覧を動的算出",
              "params": "-",
              "example": "path=<doc>"
            },
            {
              "operation": "index_scan_dir",
              "purpose": "ディレクトリ横断で index 集約",
              "params": "path=ディレクトリ",
              "example": "path=.waffle/documents/skills"
            },
            {
              "operation": "get_block",
              "purpose": "block を丸ごと取得",
              "params": "blockKey",
              "example": "blockKey=interface"
            },
            {
              "operation": "get_field",
              "purpose": "block の1フィールド取得",
              "params": "blockKey, field",
              "example": "blockKey=purpose field=text"
            },
            {
              "operation": "get_items",
              "purpose": "配列要素を全取得",
              "params": "blockKey, arrayField",
              "example": "blockKey=interface arrayField=input"
            },
            {
              "operation": "get_item_field",
              "purpose": "配列要素の特定フィールド",
              "params": "blockKey, arrayField, field",
              "example": "arrayField=input field=name"
            },
            {
              "operation": "get_items_slice",
              "purpose": "配列をスライス",
              "params": "blockKey, arrayField, start, end",
              "example": "start=0 end=5"
            },
            {
              "operation": "filter_items",
              "purpose": "key==value で配列フィルタ",
              "params": "blockKey, arrayField, key, value",
              "example": "key=required value=true"
            },
            {
              "operation": "filter_exists",
              "purpose": "field を持つ要素を抽出",
              "params": "blockKey, arrayField, field",
              "example": "field=example"
            },
            {
              "operation": "filter_pattern",
              "purpose": "field が正規表現一致",
              "params": "blockKey, arrayField, field, pattern",
              "example": "field=name pattern=^uc-"
            },
            {
              "operation": "get_by_id",
              "purpose": "idField==idValue の要素",
              "params": "blockKey, arrayField, idField, idValue",
              "example": "idField=stepId idValue=step-1"
            },
            {
              "operation": "get_nested_items",
              "purpose": "ネスト配列を展開",
              "params": "blockKey, arrayField, nestedField",
              "example": "nestedField=children"
            },
            {
              "operation": "get_children",
              "purpose": "指定要素の children",
              "params": "blockKey, arrayField, idField, idValue",
              "example": "idField=stepId idValue=step-1"
            },
            {
              "operation": "find_all",
              "purpose": "全階層を再帰検索",
              "params": "fieldName",
              "example": "fieldName=stepId"
            }
          ]
        },
        {
          "stepId": "step-3",
          "title": "選んだ operation と成型したパラメータで呼ぶ",
          "summary": "Step 2 で選んだ operation と成型したパラメータを『呼び出し』の CLI / MCP の形に当てはめて実行する（『呼び出し』に具体例あり）。"
        },
        {
          "stepId": "step-4",
          "title": "返り値 {prompt, value} を使う",
          "summary": "`value` が結果（そのまま）、`prompt` が読み方の指針。AI はファイルを直接読まず value を根拠に判断する（Harness 原則）。"
        },
        {
          "stepId": "step-5",
          "title": "不足・空一致・エラーに対処する",
          "summary": "要望に対象が無ければ『対象の指定が必要』と返す。`NO_MATCH` は空一致（正常系・`value: []`）。`INVALID_*` / `MISSING_PARAM` は入力を見直す。"
        }
      ]
    },
    "guardrails": {
      "blockType": "Guardrails",
      "title": "ガードレール",
      "items": [
        "対象（path）は呼び出し側が要望テキストで指定する。無ければ実行せず『対象の指定が必要』と返す",
        "読み取り専用。ファイルへの書き込み・削除は行わない",
        "AI はファイルを直接読まず、engine が返す value を根拠にする（Harness 原則）",
        "結果が空でも正常系として NO_MATCH（value: []）を返す",
        "例外は握りつぶさず { error, message } で返す（エラーコードは『出力』の error を参照）"
      ]
    },
    "references": {
      "blockType": "References",
      "title": "参照",
      "items": [
        {
          "path": ".waffle/documents/",
          "description": "クエリ対象となる全集約の document.json 配置ディレクトリ（skills / specs / knowledge / agents / coding）"
        },
        {
          "path": "docs/brainstorm/design-engine-query.md",
          "description": "query engine 設計ブレスト（Q-1〜Q-5）"
        }
      ]
    }
  }
}
