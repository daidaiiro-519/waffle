{
  "documentId": "test-standard-python-hexagonal",
  "documentType": "Coding",
  "schemaRef": "CodingSchema/v2",
  "codingKind": "test-standard",
  "stack": "python-hexagonal",
  "status": "ACTIVE",
  "tags": [
    "tier:backend"
  ],
  "content": {
    "title": {
      "blockType": "Title",
      "title": "test-standard-python-hexagonal"
    },
    "testStrategy": {
      "blockType": "TestStrategy",
      "title": "テスト方針",
      "pyramid": "ピラミッド形（単体テストを重視・統合はやや軽め・E2E は行わない）",
      "rationale": "業務ロジックの実装方法＝ドメインモデル"
    },
    "testPlan": {
      "blockType": "TestPlan",
      "title": "テスト計画",
      "items": [
        {
          "item": "実行タイミング",
          "value": "すべての変更（コミット前ローカル・PR で CI）"
        },
        {
          "item": "CI トリガー",
          "value": "push / pull_request"
        },
        {
          "item": "ゲート",
          "value": "シナリオ（.feature）緑が必須（Stage B ゲート1）"
        },
        {
          "item": "対象外",
          "value": "パフォーマンステスト（中核だが性能要件なし）"
        }
      ]
    },
    "testTypes": {
      "blockType": "TestTypes",
      "title": "テストタイプ",
      "items": [
        {
          "testType": "unit",
          "tool": "pytest",
          "target": "domain / application"
        },
        {
          "testType": "integration",
          "tool": "pytest",
          "target": "adapters"
        },
        {
          "testType": "acceptance",
          "tool": "pytest（AIが .feature を読んで直接執筆）",
          "target": "usecase（.feature は参照専用の仕様書）"
        },
        {
          "testType": "contract",
          "tool": "pytest（スキーマ差分検査）",
          "target": "CLI / MCP の公開インターフェース"
        }
      ]
    },
    "framework": {
      "blockType": "TestFramework",
      "title": "フレームワーク",
      "unit": "pytest",
      "acceptance": "pytest"
    },
    "scenarioBinding": {
      "blockType": "ScenarioBinding",
      "title": "シナリオの束ね方",
      "items": [
        {
          "item": ".feature の生成元",
          "rule": "spec の TestScenarios（手書きしない）"
        },
        {
          "item": ".feature の配置",
          "rule": ".waffle/specs/{contextRef}/subdomain/{subdomainRef}/usecase/{documentId}.feature（DomainSpecSchemaのx-render-target.featurePath通り・生成物・参照専用・実行対象ではない）"
        },
        {
          "item": "ネイティブテストの配置",
          "rule": "tests/acceptance/test_{spec-id}.py（AIが .feature を見て執筆・手編集前提）"
        },
        {
          "item": "対応関係",
          "rule": "1 spec（usecase）＝1 .feature（参照専用・render生成）＝1 ネイティブテストファイル（AI執筆）"
        },
        {
          "item": "ドリフト検知",
          "rule": "シナリオ名⇔テスト関数名の名前突き合わせで機械検出（未実装/孤立を検出、中身の妥当性はAIが評価）"
        }
      ]
    },
    "placementByTarget": {
      "blockType": "PlacementByTarget",
      "title": "テスト対象別の配置",
      "items": [
        {
          "target": "domain",
          "testKind": "単体",
          "path": "tests/domain/"
        },
        {
          "target": "application",
          "testKind": "単体（port はテストダブル）",
          "path": "tests/application/"
        },
        {
          "target": "adapters",
          "testKind": "結合",
          "path": "tests/adapters/"
        },
        {
          "target": "usecase の受け入れ",
          "testKind": "受け入れ（ネイティブ・.feature は参照専用）",
          "path": "tests/acceptance/"
        }
      ]
    },
    "rules": {
      "blockType": "TestRules",
      "title": "決定ルール",
      "items": [
        {
          "level": "必須",
          "rule": ".feature は実行対象ではなく、AIが読んで実装すべき参照専用の仕様書とする"
        },
        {
          "level": "必須",
          "rule": ".feature は spec から生成する（手で書かない）"
        },
        {
          "level": "禁止",
          "rule": "単体テストが実物の DB・外部サービスに依存する"
        },
        {
          "level": "推奨",
          "rule": "不変条件はテストダブルなしで検証する"
        },
        {
          "level": "必須",
          "rule": "テストファイル名は test_{対応するspecのdocumentIdをsnake_case化したもの}.py で統一する（domain/adapters/acceptanceの全層に適用。実装モジュール名を由来にした命名は禁止）"
        }
      ]
    }
  }
}
