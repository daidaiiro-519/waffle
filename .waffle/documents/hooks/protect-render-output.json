      "text": "check-path-is-projection"
    },
    "scriptRef": {
      "blockType": "ScriptRef",
      "title": "スクリプト実体",
      "text": ".waffle/hooks/protect-render-output.py"
    },
    "guardrails": {
      "blockType": "Guardrails",
      "title": "ガードレール",
      "items": [
        "新しい判定ロジックをこのHookスクリプトに持ち込まない。判定ロジックの変更はusecaseRefが指すusecase側で行う"
      ]
    }
  }
