{
  "canonicalPathTemplates": {
    "Skill": ".waffle/skills/{documentId}/SKILL.md",
    "Agent": ".waffle/agent/{documentId}.md",
    "Knowledge": ".waffle/knowledge/{status}/{documentId}.md"
  },
  "toolMappings": {
    "claude-code": {
      "Skill": { "pathTemplate": ".claude/skills/{documentId}/SKILL.md", "mode": "symlink" },
      "Agent": {
        "orchestrator": { "pathTemplate": "CLAUDE.md", "mode": "symlink" },
        "subagent": { "pathTemplate": ".claude/agents/{documentId}.md", "mode": "symlink" }
      },
      "Knowledge": { "pathTemplate": ".claude/skills/{skillRefs}/references/knowledge/{documentId}.md", "mode": "symlink" }
    },
    "codex": {
      "Agent": {
        "orchestrator": { "pathTemplate": "AGENTS.md", "mode": "symlink" }
      }
    }
  }
}
