{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AgentSchema/v1",
  "title": "Agent Schema v1",
  "description": "Document集約の一documentType（Agent）。agentKindで2種を判別する: orchestrator（CLAUDE.md/AGENTS.mdへrender+deployされる編成役）・subagent（Claude Codeのカスタムsubagent・.claude/agents/{documentId}.mdへrender+deployされる独立コンテキストの実行者）。Role/Advisor（継続対話が必要な専門レンズ）は既存SkillSchemaのskillKind=customで表現するため対象外——subagentは独立コンテキストでの一発タスク委譲を想定した別物。",

  "type": "object",
  "required": ["documentId", "documentType", "schemaRef", "agentKind", "status", "content"],
  "x-source-target": ".waffle/documents/agent/{documentId}.json",
  "if": { "properties": { "agentKind": { "const": "orchestrator" } }, "required": ["agentKind"] },
  "then": { "properties": { "content": { "$ref": "#/$defs/OrchestratorContent" } } },
  "else": { "properties": { "content": { "$ref": "#/$defs/SubagentContent" } } },

  "x-render-target": {
    "formats": ["md"],
    "pathVars": {
      "orchestrator": { "scope": "doc.content.scope.path" },
      "subagent": {}
    },
    "path": {
      "orchestrator": ".waffle/agent/{documentId}.md",
      "subagent": ".waffle/agent/{documentId}.md"
    },
    "deploy": {
      "orchestrator": ["{scope}CLAUDE.md", "{scope}AGENTS.md"],
      "subagent": [".claude/agents/{documentId}.md"]
    }
  },
  "x-frontmatter": {
    "orchestrator": {},
    "subagent": {
      "name": "doc.documentId",
      "description": "doc.content.description.text",
      "tools": "doc.content.toolAccess.tools",
      "disallowedTools": "doc.content.toolAccess.disallowedTools",
      "model": "doc.content.runtimeConfig.model",
      "permissionMode": "doc.content.runtimeConfig.permissionMode",
      "skills": "doc.content.skillPreloads.items"
    }
  },

  "properties": {
    "documentId": {
      "type": "string",
      "x-prompt-write": "このAgentを一意に識別するIDを kebab-case で付けてください。例: orchestrator-root, orchestrator-waffle, subagent-audit"
    },
    "documentType": {
      "type": "string",
      "const": "Agent"
    },
    "schemaRef": {
      "type": "string",
      "const": "AgentSchema/v1"
    },
    "agentKind": {
      "type": "string",
      "enum": ["orchestrator", "subagent"],
      "x-prompt-write": "CLAUDE.md/AGENTS.mdとして編成役を担うなら orchestrator、独立コンテキストで一発タスクを委譲されるカスタムsubagentなら subagent を指定してください。"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "ACTIVE", "DEPRECATED"],
      "x-prompt-write": "作成中は DRAFT、稼働させるなら ACTIVE、廃止する場合は DEPRECATED を指定してください。"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "x-prompt-write": "このAgentを分類するタグを付けてください。例: [\"repo:has-udd\"]"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "_index": {
      "description": "waffle が x-prompt-query から自動生成する。AI は直接書かない。",
      "readOnly": true,
      "type": "object",
      "properties": {
        "blocks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["blockType", "prompt"],
            "properties": {
              "blockType": { "type": "string" },
              "prompt": { "type": "string" }
            }
          }
        }
      }
    },
    "content": {}
  },

  "$defs": {
    "OrchestratorContent": {
      "type": "object",
      "required": ["title", "scope", "operatingRules"],
      "additionalProperties": false,
      "properties": {
        "title": { "$ref": "#/$defs/TitleBlock" },
        "scope": { "$ref": "#/$defs/ScopeBlock" },
        "operatingRules": { "$ref": "#/$defs/OperatingRulesBlock" },
        "subOrchestratorRefs": { "$ref": "#/$defs/SubOrchestratorRefsBlock" }
      }
    },

    "SubagentContent": {
      "type": "object",
      "required": ["title", "description", "systemPrompt"],
      "additionalProperties": false,
      "properties": {
        "title": { "$ref": "#/$defs/TitleBlock" },
        "description": { "$ref": "#/$defs/DescriptionBlock" },
        "toolAccess": { "$ref": "#/$defs/ToolAccessBlock" },
        "runtimeConfig": { "$ref": "#/$defs/RuntimeConfigBlock" },
        "skillPreloads": { "$ref": "#/$defs/SkillPreloadsBlock" },
        "systemPrompt": { "$ref": "#/$defs/SystemPromptBlock" }
      }
    },

    "TitleBlock": {
      "type": "object",
      "required": ["blockType", "title"],
      "x-render-order": 0,
      "x-render-level": 1,
      "x-prompt-query": "このAgentのタイトルを持ちます。documentId がそのまま使われます。",
      "x-render": [],
      "properties": {
        "blockType": { "type": "string", "const": "Title" },
        "title": { "type": "string", "x-prompt-write": "documentId をそのまま設定してください。" }
      }
    },

    "ScopeBlock": {
      "type": "object",
      "required": ["blockType", "title", "path", "description"],
      "x-render-order": 1,
      "x-render-level": 2,
      "x-prompt-query": "このOrchestratorが管轄するディレクトリと、その概要を持ちます。deploy先の解決・複数Orchestratorの管轄範囲の把握に使います。",
      "x-render": [{ "as": "keyvalue", "pairs": [{ "label": "管轄ディレクトリ", "from": "path" }, { "label": "概要", "from": "description" }] }],
      "properties": {
        "blockType": { "type": "string", "const": "Scope" },
        "title": { "type": "string", "const": "管轄範囲" },
        "path": {
          "type": "string",
          "x-prompt-write": "このOrchestratorが管轄するディレクトリをリポジトリルートからの相対パスで指定してください。ルート自身なら空文字。例: \"\", \"waffle/\""
        },
        "description": {
          "type": "string",
          "x-prompt-write": "このディレクトリ・プロダクトが何であるかを1〜2文で記述してください。"
        }
      }
    },

    "OperatingRulesBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "このscope配下で作業する際に必ず守るべき運用ルールを持ちます。CLAUDE.md/AGENTS.mdの本文として最初に読まれる指示です。",
      "x-render": [
        {
          "as": "section",
          "from": "items",
          "titleFrom": "title",
          "each": [{ "as": "paragraph", "from": "text" }]
        }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "OperatingRules" },
        "title": { "type": "string", "const": "運用ルール" },
        "items": {
          "type": "array",
          "x-prompt-write": "必ず守るべき運用ルールを列挙してください。各ルールにはタイトルと、なぜそのルールが必要かを含む説明を書いてください。",
          "items": {
            "type": "object",
            "required": ["title", "text"],
            "properties": {
              "title": { "type": "string", "x-prompt-write": "ルールの見出し。" },
              "text": { "type": "string", "x-prompt-write": "ルールの内容と、なぜ必要か（根拠）。" }
            }
          }
        }
      }
    },

    "SubOrchestratorRefsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "このOrchestratorの管轄下にある、より狭いscopeを持つ子Orchestratorへの参照を持ちます。ツールがルートしか自動発見しないため、対象scopeで作業する際は子Orchestratorのcontentを先に読むべきことを示します。子を持たないOrchestratorでは空配列。",
      "x-render": [{ "as": "table", "from": "items", "columns": [{ "field": "scope", "header": "対象ディレクトリ" }, { "field": "documentId", "header": "参照Orchestrator" }, { "field": "note", "header": "備考" }] }],
      "properties": {
        "blockType": { "type": "string", "const": "SubOrchestratorRefs" },
        "title": { "type": "string", "const": "委譲先" },
        "items": {
          "type": "array",
          "x-prompt-write": "子Orchestratorへの参照を列挙してください。子を持たなければ空配列。",
          "items": {
            "type": "object",
            "required": ["scope", "documentId", "note"],
            "properties": {
              "scope": { "type": "string", "x-prompt-write": "子Orchestratorが管轄するディレクトリ。例: \"waffle/\"" },
              "documentId": { "type": "string", "x-prompt-write": "子OrchestratorのdocumentId。" },
              "note": { "type": "string", "x-prompt-write": "そのscopeで作業する際に何を確認すべきかの短い説明。" }
            }
          }
        }
      }
    },

    "DescriptionBlock": {
      "type": "object",
      "required": ["blockType", "title", "text"],
      "x-render-order": 1,
      "x-render-level": 2,
      "x-prompt-query": "このSubagentにいつ委譲すべきかを持ちます。ClaudeがこのSubagentを選ぶかどうかの判断に使います。",
      "x-render": [{ "as": "paragraph", "from": "text" }],
      "properties": {
        "blockType": { "type": "string", "const": "Description" },
        "title": { "type": "string", "const": "委譲判断" },
        "text": {
          "type": "string",
          "x-prompt-write": "このSubagentにどんなときに委譲すべきかを具体的に記述してください。frontmatterのdescriptionとして使われ、Claudeの自動委譲判断の根拠になります。"
        }
      }
    },

    "ToolAccessBlock": {
      "type": "object",
      "required": ["blockType", "title", "tools", "disallowedTools"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "このSubagentが使えるツール・使えないツールの制限を持ちます。ブロック自体が無ければ制限なし（全ツール継承）。",
      "x-render": [
        { "heading": "使えるツール", "as": "list", "from": "tools" },
        { "heading": "使えないツール", "as": "list", "from": "disallowedTools" }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "ToolAccess" },
        "title": { "type": "string", "const": "ツール制限" },
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "x-prompt-write": "このSubagentに許可するツール名を列挙してください。全ツールを継承する場合はこのブロック自体を省略してください。"
        },
        "disallowedTools": {
          "type": "array",
          "items": { "type": "string" },
          "x-prompt-write": "このSubagentに禁止するツール名を列挙してください。無ければ空配列。"
        }
      }
    },

    "RuntimeConfigBlock": {
      "type": "object",
      "required": ["blockType", "title", "model", "permissionMode"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "このSubagentのモデル・権限モードの上書き指定を持ちます。ブロック自体が無ければメインセッションの既定を継承します。",
      "x-render": [{ "as": "keyvalue", "pairs": [{ "label": "モデル", "from": "model" }, { "label": "権限モード", "from": "permissionMode" }] }],
      "properties": {
        "blockType": { "type": "string", "const": "RuntimeConfig" },
        "title": { "type": "string", "const": "実行設定" },
        "model": {
          "type": "string",
          "x-prompt-write": "モデルを上書きする場合に指定してください（例: sonnet, opus）。既定を継承する場合はこのブロック自体を省略してください。"
        },
        "permissionMode": {
          "type": "string",
          "x-prompt-write": "権限モードを指定してください（例: default, plan）。"
        }
      }
    },

    "SkillPreloadsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 4,
      "x-render-level": 2,
      "x-prompt-query": "このSubagentが起動時にプリロードするSkill名の一覧を持ちます。ブロック自体が無ければプリロードなし。",
      "x-render": [{ "as": "list", "from": "items" }],
      "properties": {
        "blockType": { "type": "string", "const": "SkillPreloads" },
        "title": { "type": "string", "const": "プリロードSkill" },
        "items": {
          "type": "array",
          "items": { "type": "string" },
          "x-prompt-write": "起動時にプリロードするSkillのdocumentIdを列挙してください。無ければこのブロック自体を省略してください。"
        }
      }
    },

    "SystemPromptBlock": {
      "type": "object",
      "required": ["blockType", "title", "text"],
      "x-render-order": 5,
      "x-render-level": 2,
      "x-prompt-query": "このSubagentのシステムプロンプト本文を持ちます。独立コンテキストで最初に読み込まれる指示です。",
      "x-render": [{ "as": "paragraph", "from": "text" }],
      "properties": {
        "blockType": { "type": "string", "const": "SystemPrompt" },
        "title": { "type": "string", "const": "システムプロンプト" },
        "text": {
          "type": "string",
          "x-prompt-write": "このSubagentが独立コンテキストで実行する際の指示を、具体的な手順・制約を含めて記述してください。"
        }
      }
    }
  }
}
