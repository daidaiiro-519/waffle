{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CodingSchema/v1",
  "title": "CodingSchema v1",
  "description": "waffle Coding 集約の Schema。What(Spec)→How(コード) の橋渡し。codingKind で tech-stack / code-template / test-template を判別",

  "x-coding-contract": {
    "specTag":  "@spec:{specId}",
    "stackTag": "@stack:{capability}",
    "genGap":   { "start": "waffle:impl-start", "end": "waffle:impl-end" },
    "note": "全 codingKind 共通の契約定数。コードの DocComment に埋める固定書式。逆引き(ripgrep)はこの固定書式に依存する"
  },
  "x-render-target": {
    "formats": ["md"],
    "path": ".waffle/coding/{documentId}.md"
  },
  "x-source-target": ".waffle/documents/coding/{documentId}.json",

  "type": "object",
  "required": ["documentId", "documentType", "schemaRef", "codingKind", "status", "content"],
  "properties": {
    "documentId": {
      "type": "string",
      "x-prompt-write": "この Coding document を一意に識別する ID を kebab-case で。例: stack, ts-hexagonal, ts-bdd"
    },
    "documentType": { "type": "string", "const": "Coding" },
    "schemaRef":    { "type": "string", "const": "CodingSchema/v1" },
    "codingKind": {
      "type": "string",
      "enum": ["tech-stack", "code-template", "test-template"],
      "x-prompt-write": "tech-stack（言語/アーキ/library 宣言）/ code-template（コード規約+検証ルール）/ test-template（テスト規約）のいずれかを指定してください。"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "ACTIVE", "DEPRECATED"],
      "x-prompt-write": "作成中は DRAFT、利用可能になったら ACTIVE、廃止する場合は DEPRECATED を指定してください。"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "x-prompt-write": "この Coding document を分類するタグ。例: [\"stack:typescript\", \"arch:hexagonal\"]"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },

    "_index": {
      "description": "waffle が x-prompt-query から自動生成する。AI は直接書かない。",
      "readOnly": true,
      "type": "object",
      "properties": {
        "blocks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["blockType", "prompt"],
            "properties": {
              "blockType": { "type": "string" },
              "prompt":    { "type": "string" }
            }
          }
        }
      }
    },

    "content": { "type": "object" }
  },

  "allOf": [
    { "if":   { "properties": { "codingKind": { "const": "tech-stack" } }, "required": ["codingKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/TechStackContent" } } } },
    { "if":   { "properties": { "codingKind": { "const": "code-template" } }, "required": ["codingKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/CodeTemplateContent" } } } },
    { "if":   { "properties": { "codingKind": { "const": "test-template" } }, "required": ["codingKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/TestTemplateContent" } } } }
  ],

  "$defs": {

    "TechStackContent": {
      "type": "object",
      "required": ["title", "language", "architecture", "integrations", "infrastructure"],
      "additionalProperties": false,
      "properties": {
        "title":          { "$ref": "#/$defs/TitleBlock" },
        "language":       { "$ref": "#/$defs/LanguageBlock" },
        "architecture":   { "$ref": "#/$defs/ArchitectureBlock" },
        "integrations":   { "$ref": "#/$defs/IntegrationsBlock" },
        "infrastructure": { "$ref": "#/$defs/InfrastructureBlock" }
      }
    },

    "CodeTemplateContent": {
      "type": "object",
      "required": ["title", "conventions", "validationRules", "subdomainRichness"],
      "additionalProperties": false,
      "properties": {
        "title":             { "$ref": "#/$defs/TitleBlock" },
        "conventions":       { "$ref": "#/$defs/ConventionsBlock" },
        "validationRules":   { "$ref": "#/$defs/ValidationRulesBlock" },
        "subdomainRichness": { "$ref": "#/$defs/SubdomainRichnessBlock" }
      }
    },

    "TestTemplateContent": {
      "type": "object",
      "required": ["title", "testConventions", "validationRules"],
      "additionalProperties": false,
      "properties": {
        "title":           { "$ref": "#/$defs/TitleBlock" },
        "testConventions": { "$ref": "#/$defs/TestConventionsBlock" },
        "validationRules": { "$ref": "#/$defs/ValidationRulesBlock" }
      }
    },

    "TitleBlock": {
      "type": "object",
      "required": ["blockType", "title"],
      "x-render-order": 0,
      "x-render-level": 1,
      "x-prompt-query": "この Coding document のタイトルを持ちます。documentId が使われ、h1 見出しになります。",
      "x-render": [],
      "properties": {
        "blockType": { "type": "string", "const": "Title" },
        "title":     { "type": "string", "x-prompt-write": "documentId をそのまま設定してください。" }
      }
    },

    "LanguageBlock": {
      "type": "object",
      "required": ["blockType", "title", "value"],
      "x-render-order": 1,
      "x-render-level": 2,
      "x-prompt-query": "このプロジェクトの実装言語を持ちます。コード生成・検証の言語判定に使います。",
      "x-render": [
        { "as": "keyvalue", "valueCode": true, "pairs": [ { "label": "実装言語", "from": "value" } ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Language" },
        "title":     { "type": "string", "const": "実装言語" },
        "value":     { "type": "string", "x-prompt-write": "実装言語を1つ。例: typescript, python, go" }
      }
    },

    "ArchitectureBlock": {
      "type": "object",
      "required": ["blockType", "title", "architecture", "framework", "orm"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "このプロジェクトのアーキテクチャ・フレームワーク・永続化を持ちます。code-template の選択とポート/アダプタ構成の判定に使います。",
      "x-render": [
        { "as": "keyvalue", "pairs": [
          { "label": "アーキテクチャ", "from": "architecture" },
          { "label": "フレームワーク", "from": "framework" },
          { "label": "ORM", "from": "orm" }
        ] }
      ],
      "properties": {
        "blockType":    { "type": "string", "const": "Architecture" },
        "title":        { "type": "string", "const": "アーキテクチャ" },
        "architecture": { "type": "string", "x-prompt-write": "hexagonal | clean | onion | layered のいずれか。" },
        "framework":    { "type": "string", "x-prompt-write": "Web/アプリケーションフレームワークを1つ。例: express, fastapi" },
        "orm":          { "type": "string", "x-prompt-write": "永続化手段を1つ。例: typeorm, sqlalchemy, none" }
      }
    },

    "IntegrationsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "一般サブドメインの library 束縛（capability→library）を持ちます。ドメイン Spec を持たない能力の実装方針の判定に使います。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "capability" },
          { "field": "library" },
          { "field": "version" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Integrations" },
        "title":     { "type": "string", "const": "ライブラリ束縛" },
        "items": {
          "type": "array",
          "x-prompt-write": "一般サブドメインの library 束縛を列挙してください（capability→library+version）。",
          "items": {
            "type": "object",
            "required": ["capability", "library", "version"],
            "properties": {
              "capability": { "type": "string", "x-prompt-write": "能力名を kebab-case で。例: authentication, payment" },
              "library":    { "type": "string", "x-prompt-write": "採用する library 名。" },
              "version":    { "type": "string", "x-prompt-write": "固定するバージョン（再現性のため）。" }
            }
          }
        }
      }
    },

    "InfrastructureBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 4,
      "x-render-level": 2,
      "x-prompt-query": "非ドメイン共通能力のレジストリ（logging/error 等）を持ちます。@stack アンカーの宛先定義であり、共通バイパスの検出に使います。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "capability" },
          { "field": "library" },
          { "field": "version" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Infrastructure" },
        "title":     { "type": "string", "const": "共通インフラ能力" },
        "items": {
          "type": "array",
          "x-prompt-write": "非ドメインの共通能力を列挙してください（@stack の宛先）。例: logging, error-mapping",
          "items": {
            "type": "object",
            "required": ["capability", "library", "version"],
            "properties": {
              "capability": { "type": "string", "x-prompt-write": "能力名を kebab-case で。例: logging, error-mapping" },
              "library":    { "type": "string", "x-prompt-write": "採用する library 名（自作なら (custom)）。" },
              "version":    { "type": "string", "x-prompt-write": "固定するバージョン（自作なら -）。" }
            }
          }
        }
      }
    },

    "ConventionsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 1,
      "x-render-level": 2,
      "x-prompt-query": "概念ごとの配置/命名規約を持ちます。コード生成時の構造判断と配置/命名検証に使います。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "concept", "header": "概念" },
          { "field": "folder", "header": "配置", "code": true },
          { "field": "namingRule", "header": "命名規約" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Conventions" },
        "title":     { "type": "string", "const": "コード規約" },
        "items": {
          "type": "array",
          "x-prompt-write": "概念ごとの配置/命名規約を列挙してください（中立・言語非依存）。",
          "items": {
            "type": "object",
            "required": ["concept", "folder", "namingRule"],
            "properties": {
              "concept":    { "type": "string", "x-prompt-write": "概念名。例: usecase, aggregate, port, adapter" },
              "folder":     { "type": "string", "x-prompt-write": "配置フォルダ。例: src/application" },
              "namingRule": { "type": "string", "x-prompt-write": "命名/構造規約。例: {Verb}{Aggregate}・execute()" }
            }
          }
        }
      }
    },

    "ValidationRulesBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "検証ゲートが強制する機械ルールを持ちます。validate engine と Hooks がこのルールでコードを検証します。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "id" },
          { "field": "kind" },
          { "field": "spec" },
          { "field": "severity" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "ValidationRules" },
        "title":     { "type": "string", "const": "検証ルール" },
        "items": {
          "type": "array",
          "x-prompt-write": "依存方向・命名・配置・ban・必須抽象・アンカー必須のルールを列挙してください。",
          "items": {
            "type": "object",
            "required": ["id", "kind", "spec", "severity"],
            "properties": {
              "id":   { "type": "string", "x-prompt-write": "ルール ID を kebab-case で。例: dep-inward" },
              "kind": { "type": "string", "enum": ["anchor-required", "dependency", "placement", "naming", "ban", "required-abstraction"], "x-prompt-write": "ルール種別。" },
              "spec": { "type": "string", "x-prompt-write": "ルールの内容を1文で。例: domain は adapters/infra を import 不可" },
              "severity": { "type": "string", "enum": ["error", "warn"], "x-prompt-write": "違反時に BLOCK するなら error、警告なら warn。" }
            }
          }
        }
      }
    },

    "SubdomainRichnessBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "サブドメイン別の実装方法と規約の厚みを持ちます。検証ルールを一律化せず過剰設計を防ぐための較正に使います。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "subdomain", "header": "サブドメイン" },
          { "field": "implementationMethod", "header": "実装方法" },
          { "field": "conventionDepth", "header": "規約の厚み" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "SubdomainRichness" },
        "title":     { "type": "string", "const": "サブドメイン較正" },
        "items": {
          "type": "array",
          "x-prompt-write": "中核/補完/一般それぞれの実装方法と規約の厚みを定義してください。",
          "items": {
            "type": "object",
            "required": ["subdomain", "implementationMethod", "conventionDepth"],
            "properties": {
              "subdomain":            { "type": "string", "enum": ["core", "supporting", "generic"], "x-prompt-write": "サブドメイン分類。" },
              "implementationMethod": { "type": "string", "x-prompt-write": "実装方法。例: domain-model, transaction-script, library-integration" },
              "conventionDepth":      { "type": "string", "enum": ["full", "thin", "stack-only"], "x-prompt-write": "規約の厚み。中核=full、補完=thin、一般=stack-only。" }
            }
          }
        }
      }
    },

    "TestConventionsBlock": {
      "type": "object",
      "required": ["blockType", "title", "featureFolder", "stepBindingFolder", "framework"],
      "x-render-order": 1,
      "x-render-level": 2,
      "x-prompt-query": "テストの配置とフレームワーク規約を持ちます。.feature とステップバインディングの生成/配置の判定に使います。",
      "x-render": [
        { "as": "keyvalue", "valueCode": true, "pairs": [
          { "label": ".feature 配置", "from": "featureFolder" },
          { "label": "ステップバインディング配置", "from": "stepBindingFolder" },
          { "label": "フレームワーク", "from": "framework" }
        ] }
      ],
      "properties": {
        "blockType":         { "type": "string", "const": "TestConventions" },
        "title":             { "type": "string", "const": "テスト規約" },
        "featureFolder":     { "type": "string", "x-prompt-write": ".feature の配置フォルダ。例: features" },
        "stepBindingFolder": { "type": "string", "x-prompt-write": "ステップバインディングの配置フォルダ。例: features/steps" },
        "framework":         { "type": "string", "x-prompt-write": "BDD フレームワーク。例: @cucumber/cucumber, behave" }
      }
    }

  }
}
