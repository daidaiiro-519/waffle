{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "PlatformSpec/v1",
  "title": "PlatformSpec v1 (DRAFT/PROTOTYPE v3 - 全11分類)",
  "description": "検証用プロトタイプ。specKind=コンポーネント軸11分類(Compute/Storage/Database/Networking/Security/Integration/Observability/CI-CD/IoT/ML/Analytics)。資源型5分類(compute/storage/database/networking/integration)はCapacity/Resilience/ComponentSecurityの共通三分ブロックを再利用し、残り6分類(security/observability/ci-cd/iot/ml/analytics)はそれぞれの自然な中身に合わせた専用/再利用ブロックを持つ。",
  "x-render-target": {
    "formats": [
      "md"
    ],
    "path": ".waffle/specs/platform/{documentId}.md"
  },
  "x-source-target": ".waffle/documents/specs/platform/{documentId}.json",
  "type": "object",
  "required": [
    "documentId",
    "documentType",
    "schemaRef",
    "specKind",
    "content"
  ],
  "properties": {
    "documentId": {
      "type": "string"
    },
    "documentType": {
      "type": "string",
      "const": "PlatformSpec"
    },
    "schemaRef": {
      "type": "string",
      "const": "PlatformSpec/v1"
    },
    "specKind": {
      "type": "string",
      "enum": [
        "compute",
        "storage",
        "database",
        "networking",
        "security",
        "integration",
        "observability",
        "ci-cd",
        "iot",
        "ml",
        "analytics"
      ]
    },
    "content": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "compute"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/ResourceContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "storage"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/ResourceContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "database"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/ResourceContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "networking"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/NetworkingContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "integration"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/ResourceContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "iot"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/IotContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "security"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/SecurityContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "observability"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/ObservabilityContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "ci-cd"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/CiCdContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "ml"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/MlContent"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "specKind": {
            "const": "analytics"
          }
        },
        "required": [
          "specKind"
        ]
      },
      "then": {
        "properties": {
          "content": {
            "$ref": "#/$defs/AnalyticsContent"
          }
        }
      }
    }
  ],
