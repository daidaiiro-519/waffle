{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "DomainSpecSchema/v2",
  "title": "DomainSpecSchema v2",
  "description": "waffle の Spec 家族のうち、業務ロジック層（ドメイン層・DDD管轄）を扱う Spec 集約（UDD の核）。旧称 SpecSchema（spec は DDD より広い上位概念であり、UI層を扱う PresentationSpecSchema が別家族として存在するため改名）。specKind=bounded-context/subdomain/aggregate/usecase（DDD 語彙に整合）。content はドメイン語彙のみ（技術スタック/アーキ構成は CodingTemplate の担当）。集約=Commands/Invariants/Lifecycle、ユースケース=基本フロー(シーケンス)、整合の契約=TestScenarios(Gherkin)。描画は MD を正本とする（Google OKF 整合のため HTML は生成しない・HTML が要る場合は既存技術で MD から導出する viewer 側の責務）。",

  "x-render-target": {
    "formats": ["md", "feature"],
    "path": ".waffle/specs/{documentId}.md",
    "featurePath": ".waffle/specs/{documentId}.feature"
  },
  "x-source-target": ".waffle/documents/specs/{documentId}.json",

  "x-lifecycle": {
    "transitions": [
      { "from": null,        "to": "CREATED",    "command": "create" },
      { "from": "CREATED",   "to": "VALIDATED",  "command": "validate" },
      { "from": "VALIDATED", "to": "VALIDATED",  "command": "validate" },
      { "from": "RENDERED",  "to": "RENDERED",   "command": "validate" },
      { "from": "VALIDATED", "to": "RENDERED",   "command": "render" },
      { "from": "VALIDATED", "to": "SUPERSEDED", "command": "supersede" },
      { "from": "RENDERED",  "to": "SUPERSEDED", "command": "supersede" }
    ]
  },

  "type": "object",
  "required": ["documentId", "documentType", "schemaRef", "specKind", "status", "content"],
  "properties": {
    "documentId": {
      "type": "string",
      "x-prompt-write": "この Spec を一意に識別する ID を kebab-case で。bounded-context は bc-、subdomain は sd-、aggregate は agg-、usecase は uc- 接頭辞を推奨。例: uc-place-order"
    },
    "documentType": { "type": "string", "const": "DomainSpec" },
    "schemaRef":    { "type": "string", "const": "DomainSpecSchema/v2" },
    "specKind": {
      "type": "string",
      "enum": ["bounded-context", "subdomain", "aggregate", "usecase"],
      "x-prompt-write": "DDDの階層で選ぶ。bounded-context=同じ言葉が通る境界(製品文脈・最外) / subdomain=その中の業務領域(中核/一般/補完・ユースケースの束) / aggregate=一貫性の単位(不変条件を持つ実体・名詞) / usecase=1つの操作(動詞)。迷ったら: 不変条件を持つ実体→aggregate、〜する操作→usecase、業務の括り→subdomain、文脈全体→bounded-context。"
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "VALIDATED", "RENDERED", "SUPERSEDED"],
      "x-prompt-write": "作成直後は CREATED。検証通過で VALIDATED、render 済で RENDERED、後続版に置換で SUPERSEDED。"
    },
    "subdomainRef": {
      "type": "string",
      "x-prompt-write": "usecase のみ: この操作が属する subdomain の documentId。例: sd-order-management"
    },
    "aggregateRef": {
      "type": "string",
      "x-prompt-write": "usecase のみ: この操作が対象とする aggregate の documentId。アプリ→ドメインの依存。"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "x-prompt-write": "この Spec を分類するタグ。例: [\"context:orders\"]"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },

    "_index": {
      "description": "waffle が x-prompt-query から自動生成する。AI は直接書かない。",
      "readOnly": true,
      "type": "object",
      "properties": {
        "blocks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["blockType", "prompt"],
            "properties": {
              "blockType": { "type": "string" },
              "prompt":    { "type": "string" }
            }
          }
        }
      }
    },

    "content": { "type": "object" }
  },

  "allOf": [
    { "if":   { "properties": { "specKind": { "const": "bounded-context" } }, "required": ["specKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/BoundedContextContent" } } } },
    { "if":   { "properties": { "specKind": { "const": "subdomain" } }, "required": ["specKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/SubdomainContent" } } } },
    { "if":   { "properties": { "specKind": { "const": "aggregate" } }, "required": ["specKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/AggregateContent" } } } },
    { "if":   { "properties": { "specKind": { "const": "usecase" } }, "required": ["specKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/UsecaseContent" } } } }
  ],

  "$defs": {

    "BoundedContextContent": {
      "type": "object",
      "required": ["title", "summary", "ubiquitousLanguage", "members"],
      "additionalProperties": false,
      "properties": {
        "title":              { "$ref": "#/$defs/TitleBlock" },
        "summary":            { "$ref": "#/$defs/SummaryBlock" },
        "ubiquitousLanguage": { "$ref": "#/$defs/UbiquitousLanguageBlock" },
        "members":            { "$ref": "#/$defs/MembersBlock" },
        "contextMap":         { "$ref": "#/$defs/ContextMapBlock" }
      }
    },

    "SubdomainContent": {
      "type": "object",
      "required": ["title", "summary", "category", "members", "implementationGuidance"],
      "additionalProperties": false,
      "properties": {
        "title":                  { "$ref": "#/$defs/TitleBlock" },
        "summary":                { "$ref": "#/$defs/SummaryBlock" },
        "category":               { "$ref": "#/$defs/SubdomainCategoryBlock" },
        "members":                { "$ref": "#/$defs/SubdomainMembersBlock" },
        "implementationGuidance": { "$ref": "#/$defs/ImplementationGuidanceBlock" },
        "externalSolution":       { "$ref": "#/$defs/ExternalSolutionBlock" },
        "domainServices":         { "$ref": "#/$defs/DomainServicesBlock" }
      }
    },

    "AggregateContent": {
      "type": "object",
      "required": ["title", "summary", "aggregateRoot", "entities", "invariants", "commands"],
      "additionalProperties": false,
      "properties": {
        "title":             { "$ref": "#/$defs/TitleBlock" },
        "summary":           { "$ref": "#/$defs/SummaryBlock" },
        "aggregateRoot":     { "$ref": "#/$defs/AggregateRootBlock" },
        "entities":          { "$ref": "#/$defs/EntitiesBlock" },
        "valueObjects":      { "$ref": "#/$defs/ValueObjectsBlock" },
        "invariants":        { "$ref": "#/$defs/InvariantsBlock" },
        "lifecycle":         { "$ref": "#/$defs/LifecycleBlock" },
        "maturityLifecycle": { "$ref": "#/$defs/LifecycleBlock" },
        "commands":          { "$ref": "#/$defs/CommandsBlock" },
        "domainEvents":      { "$ref": "#/$defs/DomainEventsBlock" },
        "unitTestScenarios": { "$ref": "#/$defs/TestScenariosBlock" }
      }
    },

    "UsecaseContent": {
      "type": "object",
      "required": ["title", "summary", "actorIntent", "mainFlow", "postconditions", "acceptanceCriteria", "testScenarios"],
      "additionalProperties": false,
      "properties": {
        "title":              { "$ref": "#/$defs/TitleBlock" },
        "summary":            { "$ref": "#/$defs/SummaryBlock" },
        "actorIntent":        { "$ref": "#/$defs/ActorIntentBlock" },
        "externalActors":     { "$ref": "#/$defs/ExternalActorsBlock" },
        "preconditions":      { "$ref": "#/$defs/PreconditionsBlock" },
        "mainFlow":           { "$ref": "#/$defs/MainFlowBlock" },
        "postconditions":     { "$ref": "#/$defs/PostconditionsBlock" },
        "acceptanceCriteria": { "$ref": "#/$defs/AcceptanceCriteriaBlock" },
        "errors":             { "$ref": "#/$defs/ErrorsBlock" },
        "testScenarios":      { "$ref": "#/$defs/TestScenariosBlock" }
      }
    },

    "TitleBlock": {
      "type": "object",
      "required": ["blockType", "title"],
      "x-render-order": 0,
      "x-render-level": 1,
      "x-prompt-query": "この Spec のタイトルを持ちます。documentId が使われ h1 になります。",
      "x-render": [],
      "properties": {
        "blockType": { "type": "string", "const": "Title" },
        "title":     { "type": "string", "x-prompt-write": "documentId をそのまま設定してください。" }
      }
    },

    "SummaryBlock": {
      "type": "object",
      "required": ["blockType", "title", "text"],
      "x-render-order": 1,
      "x-render-level": 2,
      "x-prompt-query": "この Spec の概要を1〜2文で持ちます。人の即スキャンと AI の意図把握に使います。",
      "x-render": [ { "as": "paragraph", "from": "text" } ],
      "properties": {
        "blockType": { "type": "string", "const": "Summary" },
        "title":     { "type": "string", "const": "概要" },
        "text":      { "type": "string", "x-prompt-write": "この文脈/業務領域/集約/ユースケースが何かを1〜2文で（ドメイン語彙のみ・技術用語禁止）。" }
      }
    },

    "UbiquitousLanguageBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "この文脈のユビキタス言語(用語→定義)を持ちます。AI の grounding・語彙統一に使います。この bc 内に閉じます。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "term", "header": "用語", "code": true },
          { "field": "definition", "header": "定義" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "UbiquitousLanguage" },
        "title":     { "type": "string", "const": "ユビキタス言語" },
        "items": {
          "type": "array",
          "x-prompt-write": "この文脈の主要な用語と定義を網羅的に列挙。業務エキスパートと同じ言葉で（技術用語を混ぜない）。",
          "items": {
            "type": "object",
            "required": ["term", "definition"],
            "properties": {
              "term":       { "type": "string", "x-prompt-write": "用語（この文脈での呼び名）。" },
              "definition": { "type": "string", "x-prompt-write": "その用語が指すものを1文で。" }
            }
          }
        }
      }
    },

    "MembersBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "この bc に属する subdomain/aggregate/usecase の一覧を持ちます。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "kind", "header": "種別" },
          { "field": "members", "header": "メンバー" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Members" },
        "title":     { "type": "string", "const": "構成要素" },
        "items": {
          "type": "array",
          "x-prompt-write": "種別ごとに所属メンバーの id を列挙。",
          "items": {
            "type": "object",
            "required": ["kind", "members"],
            "properties": {
              "kind":    { "type": "string", "enum": ["subdomain", "aggregate", "usecase"], "x-prompt-write": "メンバーの種別。" },
              "members": { "type": "string", "x-prompt-write": "その種別の id を「 / 」区切りで。例: sd-order-management / sd-payment" }
            }
          }
        }
      }
    },

    "ContextMapBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 4,
      "x-render-level": 2,
      "x-prompt-query": "他の bounded-context との連係(相手・関係種別・内容)を持ちます。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "counterpart", "header": "相手コンテキスト" },
          { "field": "relationship", "header": "関係" },
          { "field": "content", "header": "内容" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "ContextMap" },
        "title":     { "type": "string", "const": "文脈マップ" },
        "items": {
          "type": "array",
          "x-prompt-write": "他 bc との関係を列挙。関係種別=パートナー/顧客・供給/従属/腐敗防止層/公開された言語 等。1 bc しか無ければ空。",
          "items": {
            "type": "object",
            "required": ["counterpart", "relationship", "content"],
            "properties": {
              "counterpart":  { "type": "string", "x-prompt-write": "相手の bounded-context 名。" },
              "relationship": { "type": "string", "x-prompt-write": "関係種別（パートナー/顧客・供給/腐敗防止層 等）。" },
              "content":      { "type": "string", "x-prompt-write": "何を連係するかを1文で。" }
            }
          }
        }
      }
    },

    "SubdomainCategoryBlock": {
      "type": "object",
      "required": ["blockType", "title", "classification", "rationale"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "この業務領域のカテゴリー(中核/一般/補完)と根拠を持ちます。実装の厚みを駆動します。",
      "x-render": [
        { "as": "keyvalue", "pairs": [
          { "label": "カテゴリー", "from": "classification" },
          { "label": "根拠", "from": "rationale" }
        ] }
      ],
      "properties": {
        "blockType":      { "type": "string", "const": "SubdomainCategory" },
        "title":          { "type": "string", "const": "カテゴリー" },
        "classification": { "type": "string", "enum": ["core", "supporting", "generic"], "x-prompt-write": "中核=core / 補完=supporting / 一般=generic。競争優位を生むか・既製品があるかで判定。" },
        "rationale":      { "type": "string", "x-prompt-write": "そのカテゴリーである根拠（差別化の有無）。" }
      }
    },

    "SubdomainMembersBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "この業務領域に属するユースケースの一覧を持ちます。",
      "x-render": [ { "as": "list", "from": "items" } ],
      "properties": {
        "blockType": { "type": "string", "const": "SubdomainMembers" },
        "title":     { "type": "string", "const": "所属ユースケース" },
        "items": {
          "type": "array",
          "x-prompt-write": "この業務領域に属する usecase の id を列挙。",
          "items": { "type": "string" }
        }
      }
    },

    "ImplementationGuidanceBlock": {
      "type": "object",
      "required": ["blockType", "title", "text"],
      "x-render-order": 4,
      "x-render-level": 2,
      "x-prompt-query": "この業務領域の実装の厚み(中核=厚い/一般=既製/補完=薄い)を持ちます。CodingTemplate の subdomainRichness の宣言元。",
      "x-render": [ { "as": "paragraph", "from": "text" } ],
      "properties": {
        "blockType": { "type": "string", "const": "ImplementationGuidance" },
        "title":     { "type": "string", "const": "実装ガイド" },
        "text":      { "type": "string", "x-prompt-write": "実装方針を1〜2文で。中核=ドメインモデルで厚く/一般=既製ライブラリを薄く包む/補完=薄いトランザクションスクリプト。" }
      }
    },

    "ExternalSolutionBlock": {
      "type": "object",
      "required": ["blockType", "title", "text"],
      "x-render-order": 5,
      "x-render-level": 2,
      "x-prompt-query": "一般の業務領域で採用する既製品(@stack の宛先)を持ちます。",
      "x-render": [ { "as": "paragraph", "from": "text" } ],
      "properties": {
        "blockType": { "type": "string", "const": "ExternalSolution" },
        "title":     { "type": "string", "const": "外部解決策" },
        "text":      { "type": "string", "x-prompt-write": "採用する既製ライブラリ/サービス名と、それが @stack のどの能力に当たるか。中核/補完なら不要。" }
      }
    },

    "DomainServicesBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 6,
      "x-render-level": 2,
      "x-prompt-query": "業務サービス(ステートレス・複数集約にまたがる計算)を持ちます。集約に属さないためここ(subdomain)に置きます。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "name", "header": "業務サービス" },
          { "field": "responsibility", "header": "責務" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "DomainServices" },
        "title":     { "type": "string", "const": "ドメインサービス" },
        "items": {
          "type": "array",
          "x-prompt-write": "複数集約に跨る/集約に収まらないステートレスな業務ロジックを列挙。無ければ空。",
          "items": {
            "type": "object",
            "required": ["name", "responsibility"],
            "properties": {
              "name":           { "type": "string", "x-prompt-write": "業務サービス名。" },
              "responsibility": { "type": "string", "x-prompt-write": "何を計算/判定するか・どの集約に跨るか・入力→出力（何を受け何を返すか）を1文で。実装手順は書かない。" }
            }
          }
        }
      }
    },

    "AggregateRootBlock": {
      "type": "object",
      "required": ["blockType", "title", "name"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "集約のルート名と外部集約参照を持ちます。集約境界の核です。",
      "x-render": [
        { "as": "keyvalue", "pairs": [ { "label": "集約ルート", "from": "name" } ] },
        { "as": "list", "heading": "外部参照（ID）", "from": "externalRefs" }
      ],
      "properties": {
        "blockType":    { "type": "string", "const": "AggregateRoot" },
        "title":        { "type": "string", "const": "集約ルート" },
        "name":         { "type": "string", "x-prompt-write": "ルートエンティティ名（ドメイン語彙）。例: Order" },
        "externalRefs": {
          "type": "array",
          "x-prompt-write": "ID で参照する他集約を列挙（オブジェクトは内部に持たない・図6-4）。例: Customer, Product。無ければ空。",
          "items": { "type": "string" }
        }
      }
    },

    "EntitiesBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "集約内のエンティティ(ルート＋子・識別子＋属性)を持ちます。ルートを通じてのみ変更されます。",
      "x-render": [
        { "as": "section", "from": "items", "titleFrom": "name", "badge": { "from": "isRoot", "text": "集約ルート" }, "each": [
          { "as": "paragraph", "from": "role" },
          { "as": "table", "from": "attributes", "columns": [
            { "field": "name", "header": "属性", "markField": "isId", "markSuffix": "（識別子）" },
            { "field": "type", "header": "型" }
          ] }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Entities" },
        "title":     { "type": "string", "const": "エンティティ" },
        "items": {
          "type": "array",
          "x-prompt-write": "集約内エンティティ（識別子を持ち状態が変わる）を列挙。最低1つ＝集約ルート。",
          "items": {
            "type": "object",
            "required": ["name", "role", "isRoot", "attributes"],
            "properties": {
              "name":       { "type": "string", "x-prompt-write": "エンティティ名。例: Order / OrderLine" },
              "role":       { "type": "string", "x-prompt-write": "役割を1文で。" },
              "isRoot":     { "type": "boolean", "x-prompt-write": "集約ルートなら true（1つだけ）。" },
              "attributes": {
                "type": "array",
                "minItems": 1,
                "x-prompt-write": "属性を列挙。識別子も属性の1つとして含め isId:true を付ける。型は値オブジェクト名で。",
                "items": {
                  "type": "object",
                  "required": ["name", "type"],
                  "properties": {
                    "name": { "type": "string", "x-prompt-write": "属性名。例: status / orderId" },
                    "type": { "type": "string", "x-prompt-write": "型（値オブジェクト名・他エンティティ・ID）。例: OrderStatus / OrderLine[] / customerId" },
                    "isId": { "type": "boolean", "x-prompt-write": "この属性が識別子なら true（エンティティに1つ）。" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "ValueObjectsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 4,
      "x-render-level": 2,
      "x-prompt-query": "値オブジェクト(属性の型カタログ・不変・振る舞い)を持ちます。エンティティ属性の型を定義します。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "name", "header": "値オブジェクト" },
          { "field": "represents", "header": "表すもの" },
          { "field": "behavior", "header": "振る舞い・制約" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "ValueObjects" },
        "title":     { "type": "string", "const": "値オブジェクト" },
        "items": {
          "type": "array",
